{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: gcc.exe 生成活动文件",
      "command": "gcc",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "-I", "${workspaceFolder}/inc",
        "${workspaceFolder}/main.c",
        "${workspaceFolder}/src/*.c",
        "-o",
        "${workspaceFolder}/main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}