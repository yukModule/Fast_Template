# ============================================================
#  Makefile — DLL 开发模板
#
#  目标：
#    main.exe      — 主程序（运行时动态加载 DLL）
#    dll_fun.dll   — 动态链接库（提供 dll_print 函数）
#
#  用法：
#    make          编译所有目标
#    make clean    清理生成的文件
# ============================================================

# 编译器
CC = gcc

# 编译选项：-Wall 显示所有警告，-g 包含调试信息
CFLAGS = -Wall -g

# 头文件目录
INCDIR = inc
INCLUDES = -I$(INCDIR)

# 输出目标
TARGET = main.exe
DLL_TARGET = dll_fun.dll

# ============================================================
# 默认目标
# ============================================================
all: $(TARGET) $(DLL_TARGET)

# ============================================================
# 编译 DLL（动态链接库）
# -shared   : 告诉 gcc 生成共享库（.dll）
# -I$(INCDIR): 指定头文件搜索路径
# ============================================================
$(DLL_TARGET): src/dll_fun.c inc/dll_fun.h
	$(CC) -shared $(CFLAGS) $(INCLUDES) -o $@ src/dll_fun.c

# ============================================================
# 编译主程序（.exe）
# main.c 不需要链接 DLL，因为它使用 LoadLibrary 在运行时加载。
# 因此这里只是一次普通的 .exe 编译。
# ============================================================
$(TARGET): main.c
	$(CC) $(CFLAGS) -o $@ main.c

# ============================================================
# 清理
# ============================================================
clean:
	rm -f $(TARGET) $(DLL_TARGET)

# 声明 phony 目标（不与文件名冲突）
.PHONY: all clean
